# .env.example — 実値は代表者（C）から Slack DM で受け取り .env に記入する
# .env は Git 管理外で運用する。

APP_ENV=development
LOG_LEVEL=INFO

# ===== Google Gemini =====
GOOGLE_API_KEY=
LLM_MODEL=gemini-2.5-flash

# ===== Database =====
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=closet
DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/closet

# ===== Stripe =====
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_BASIC=

# # ===== Supabase =====
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== MinIO =====
# STORAGE_ENDPOINT=http://minio:9000
