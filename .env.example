# 実値は代表者（C）から Slack DM で受け取り、ローカルでは .env または frontend/.env.local に記入する
# .env / .env.local は Git 管理外で運用する。

APP_ENV=development  # 開発モード or　本番モードの切り替え。production にすると、ログレベルが INFO から WARNING に上がる。
LOG_LEVEL=INFO
AUTH_BYPASS_ENABLED=false   # true のときだけ、引き続きモックユーザーを返します。Supabase 設定が無いままバイパスも無効なら認証は通りません。
BACKEND_CORS_ORIGINS=["http://localhost:3000"]  # JSON形式の文字列で指定（例: ["http://localhost:3000","http://127.0.0.1:3000"]）


# ===== OpenAI =====
# OPENAI_API_KEY=sk-xxxxx
OPENAI_MODEL=gpt-5

# ===== Database =====
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=closet
DATABASE_URL=postgresql+psycopg://app:app@postgres:5432/closet

# ===== Stripe =====
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_BASIC=

# ===== Supabase =====
# Frontend / Next.js public env
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy anon key. Frontend should use NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY instead.
# SUPABASE_ANON_KEY=

# Backend / server-only env
#SUPABASE_URL=
STORAGE_BUCKET=clothes-images

# ===== Redis =====
REDIS_URL=redis://redis:6379/0
