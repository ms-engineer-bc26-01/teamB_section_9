# 実値は代表者（C）から Slack DM で受け取り、ローカルでは .env または frontend/.env.local に記入する
# .env / .env.local は Git 管理外で運用する。

# ===== frontend =====
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ===== backend =====
APP_ENV=development  # 開発モード or　本番モードの切り替え。production にすると、ログレベルが INFO から WARNING に上がる。
LOG_LEVEL=INFO
AUTH_BYPASS_ENABLED=false   # true のときだけ、引き続きモックユーザーを返します。Supabase 設定が無いままバイパスも無効なら認証は通りません。
BACKEND_CORS_ORIGINS=["http://localhost:3000"]  # JSON形式の文字列で指定（例: ["http://localhost:3000","http://127.0.0.1:3000"]）

DATABASE_URL=postgresql+psycopg://<USERNAME>:<PASSWORD>@postgres:5432/<DB_NAME>
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
OPENAI_IMAGE_MODEL=gpt-image-1-mini   # コラージュ画像生成モデル
OPENAI_IMAGE_SIZE=1024x1024      # 生成画像サイズ
OPENAI_IMAGE_TIMEOUT_SECONDS=60  # 画像生成APIのタイムアウト（秒）

SUPABASE_URL=https://XXXXX.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxx
# サーバ側 Storage アップロード用（RLS をバイパスする service role key）。画像生成統合で必須。
SUPABASE_SERVICE_ROLE_KEY=

# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_BASIC=

SUPABASE_STORAGE_BUCKET=clothes-images   # コラージュ画像・服画像を保存する Supabase Storage バケット

# ===== Database =====
POSTGRES_USER=<USERNAME>
POSTGRES_PASSWORD=<PASSWORD>
POSTGRES_DB=<DB_NAME>


# ===== Redis =====
# docker-compose の redis サービスに接続。ローカル単体起動時は redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0
REDIS_WEATHER_TTL_SECONDS=1800    # 天気キャッシュ 30分
REDIS_OUTFIT_TTL_SECONDS=86400    # コーデキャッシュ 24時間（要件 3.4 / Redisキー設計）
